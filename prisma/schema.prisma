generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(uuid()) @db.Uuid
  email        String      @unique
  passwordHash String      @map("password_hash")
  createdAt    DateTime    @default(now()) @map("created_at")

  notes        Note[]
  sharedNotes  NoteShare[]

  @@map("users")
}

model Note {
  id        String      @id @default(uuid()) @db.Uuid
  ownerId   String      @map("owner_id") @db.Uuid
  title     String
  content   String      @default("")
  pinned    Boolean     @default(false)
  position  Int         @default(0)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt      @map("updated_at")

  owner     User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  shares    NoteShare[]
  versions  NoteVersion[]

  @@index([ownerId])
  @@index([ownerId, pinned, position, updatedAt])
  @@map("notes")
}

model NoteVersion {
  id        String   @id @default(uuid()) @db.Uuid
  noteId    String   @map("note_id") @db.Uuid
  versionNo Int      @map("version_no")
  title     String
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, versionNo])
  @@index([noteId, versionNo])
  @@map("note_versions")
}

model NoteShare {
  noteId   String   @map("note_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  sharedAt DateTime @default(now()) @map("shared_at")

  note     Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([noteId, userId])
  @@index([userId])
  @@map("note_shares")
}
